#!/usr/bin/env bash
# System launcher for HyprGlass Studio.
# Installed by the Makefile / PKGBUILD / .deb package.

set -euo pipefail

SCRIPT_PATH="$(readlink -f "$0")"
PREFIX="$(dirname "$(dirname "${SCRIPT_PATH}")")"
STUDIO_LIB="${PREFIX}/lib/hyprglass-studio"

if [[ ! -d "${STUDIO_LIB}" ]]; then
    echo "Error: HyprGlass Studio is not installed in ${STUDIO_LIB}" >&2
    exit 1
fi

exec python3 "${STUDIO_LIB}/src/server.py" "$@"
